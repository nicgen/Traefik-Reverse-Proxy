# ============================================================================
# Environment and Secrets
# ============================================================================
.env
.env.*
!.env.example
*.key
*.pem
*.crt
secrets/
credentials.json
1password-credentials.json

# ============================================================================
# Let's Encrypt / Traefik Certificates
# ============================================================================
letsencrypt/acme.json
letsencrypt/*.json
letsencrypt/certificates/

# ============================================================================
# Application Data Directories
# ============================================================================
# Traefik
traefik/data/
traefik/logs/
traefik/*.log

# WUD (What's Up Docker)
wud/data/
wud/config/config.yml
!wud/config/.gitkeep

# Kasm Workspaces
kasm/data/
kasm/profiles/
kasm/logs/
kasm/*.db
kasm/*.sqlite

# ============================================================================
# Docker Volumes and Runtime Data
# ============================================================================
volumes/
data/
*.sock

# ============================================================================
# Logs
# ============================================================================
*.log
logs/
*.log.*
*.log.gz

# ============================================================================
# Backup Files
# ============================================================================
*.bak
*.backup
*.old
*.tmp
*.swp
*.swo
*~

# ============================================================================
# IDE and Editor Files
# ============================================================================
.vscode/
.idea/
*.iml
.DS_Store
Thumbs.db

# ============================================================================
# Operating System Files
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# ============================================================================
# Temporary Files
# ============================================================================
tmp/
temp/
*.tmp
*.temp

# ============================================================================
# Docker Compose Override Files (if using per-developer overrides)
# ============================================================================
docker-compose.override.yml

# ============================================================================
# SSL/TLS Private Keys and Certificates (except templates)
# ============================================================================
*.pem
*.key
*.csr
*.crt
!*.example.crt

# ============================================================================
# Database Files
# ============================================================================
*.db
*.sqlite
*.sqlite3

# ============================================================================
# Archive Files
# ============================================================================
*.zip
*.tar
*.tar.gz
*.tgz
*.rar

# ============================================================================
# Node modules (if using any Node-based tools)
# ============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================================
# Python (if using any Python-based tools)
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
env/
ENV/

# ============================================================================
# Terraform State (if using IaC)
# ============================================================================
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# ============================================================================
# Keep Directory Structure
# ============================================================================
!.gitkeep
.env.local
