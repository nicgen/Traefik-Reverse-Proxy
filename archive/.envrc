# ============================================================================
# 1Password Developer Environment Configuration
# ============================================================================
# This file defines environment variables loaded from 1Password Developer Environment
# Use with: op run --env-file=.envrc -- <command>
#
# DO NOT commit this file if it contains sensitive values
# This is a template - actual values are stored in 1Password
# ============================================================================

# Global Configuration
export DOMAIN_NAME="op://docker-dev-env/config/domain_name"

# Traefik Configuration
export ACME_EMAIL="op://docker-dev-env/config/acme_email"
export CLOUDFLARE_API_TOKEN="op://docker-dev-env/config/cloudflare_api_token"

# Kasm Configuration
export KASM_PORT="op://docker-dev-env/config/kasm_port"
export KASM_DATA_PATH="op://docker-dev-env/config/kasm_data_path"
export KASM_ADMIN_USER="op://docker-dev-env/config/kasm_admin_user"
export KASM_ADMIN_PASSWORD="op://docker-dev-env/config/kasm_admin_password"

# Docker Hub Credentials
export DOCKER_HUB_USERNAME="op://docker-dev-env/config/docker_hub_username"
export DOCKER_HUB_PASSWORD="op://docker-dev-env/config/docker_hub_password"

# What's Up Docker Configuration
export WUD_CONFIG_PATH="op://docker-dev-env/config/wud_config_path"
export WUD_DATA_PATH="op://docker-dev-env/config/wud_data_path"
export WUD_API_PORT="op://docker-dev-env/config/wud_api_port"
export WUD_REGISTRY_PROVIDER="op://docker-dev-env/config/wud_registry_provider"
