# ============================================================================
# Docker Development Environment - Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
#
# Quick setup:
#   cp .env.example .env
#   nano .env  # Edit with your values
# ============================================================================

# ============================================================================
# Global Configuration
# ============================================================================
DOMAIN_NAME=local.dev

# ============================================================================
# Traefik Configuration (DNS-01 Challenge with Cloudflare)
# ============================================================================
# Traefik Dashboard: http://localhost:8080 (api.insecure=true for local dev)
# Production: Set api.insecure=false and use authentication

# ACME Email for Let's Encrypt certificate notifications
# This email will receive certificate expiration warnings
ACME_EMAIL=your-email@example.com

# Cloudflare API Token for DNS-01 challenge
# Generate at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone.DNS.Edit for your domain
# Scope: Include -> Specific zone -> your-domain.com
CLOUDFLARE_API_TOKEN=your-cloudflare-dns-api-token-here

# ============================================================================
# What's Up Docker (WUD) Configuration
# ============================================================================
# WUD monitors your containers for image updates
WUD_CONFIG_PATH=./wud/config
WUD_DATA_PATH=./wud/data
WUD_API_PORT=3000
WUD_REGISTRY_PROVIDER=docker

# ============================================================================
# Kasm Workspaces Configuration
# ============================================================================
# Kasm provides browser-based container streaming

# Web interface port
KASM_PORT=6901

# Data persistence path
KASM_DATA_PATH=./kasm/data

# Admin credentials
# SECURITY: Change these before first deployment
KASM_ADMIN_USER=admin
KASM_ADMIN_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ============================================================================
# Docker Hub Credentials (Optional)
# ============================================================================
# Only needed if pulling private images or to avoid rate limits
# Leave empty if not needed
DOCKER_HUB_USERNAME=your-dockerhub-username
DOCKER_HUB_PASSWORD=your-dockerhub-password-or-token

# ============================================================================
# Security Checklist
# ============================================================================
# [ ] Changed all default passwords
# [ ] Set strong KASM_ADMIN_PASSWORD (16+ characters, mixed case, numbers, symbols)
# [ ] Verified CLOUDFLARE_API_TOKEN has minimal required permissions
# [ ] Added .env to .gitignore
# [ ] Considered using 1Password CLI for secret management
# [ ] Reviewed docker-compose-secure.yml for Docker socket protection
# [ ] Set appropriate file permissions: chmod 600 .env
# [ ] Documented secret rotation schedule
#
# Production additional checklist:
# [ ] Disabled Traefik insecure API (api.insecure=false)
# [ ] Implemented Docker Socket Proxy
# [ ] Enabled HTTPS-only redirects
# [ ] Configured firewall rules
# [ ] Set up monitoring and alerting
# [ ] Implemented backup strategy
# [ ] Documented disaster recovery procedures
# ============================================================================

# ============================================================================
# 1Password Integration (Optional)
# ============================================================================
# If using 1Password CLI, you can reference secrets like:
# CLOUDFLARE_API_TOKEN=op://vault-name/item-name/field-name
#
# Then run with:
# op run --env-file=.env -- docker-compose up -d
#
# Vault structure suggestion:
# Infrastructure/
#   traefik/
#     cloudflare_token
#     acme_email
#   docker/
#     username
#     password
#   kasm/
#     admin_username
#     admin_password
# ============================================================================
